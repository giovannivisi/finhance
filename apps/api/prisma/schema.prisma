generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Asset {
  id            String         @id @default(cuid())
  userId        String
  name          String
  type          AssetType
  balance       Decimal        @db.Decimal(20, 10)
  currency      String         @default("EUR")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  kind          AssetKind?
  notes         String?
  order         Int?           @default(0)
  ticker        String?
  liabilityKind LiabilityKind?
  exchange      String?
  quantity      Decimal?       @db.Decimal(20, 10)
  unitPrice     Decimal?       @db.Decimal(20, 10)
  lastPrice     Decimal?       @db.Decimal(20, 10)
  lastPriceAt   DateTime?
  lastFxRate    Decimal?       @db.Decimal(20, 10)
  lastFxRateAt  DateTime?
  accountId     String?
  importSource  ImportSource?
  importKey     String?
  account       Account?       @relation(fields: [accountId, userId], references: [id, userId])

  @@unique([userId, type, kind, ticker, exchange])
  @@unique([userId, importSource, importKey])
  @@index([userId])
  @@index([userId, accountId])
}

model Account {
  id                            String                     @id @default(cuid())
  userId                        String
  name                          String
  type                          AccountType
  currency                      String                     @default("EUR")
  institution                   String?
  notes                         String?
  order                         Int                        @default(0)
  archivedAt                    DateTime?
  createdAt                     DateTime                   @default(now())
  updatedAt                     DateTime                   @updatedAt
  importSource                  ImportSource?
  importKey                     String?
  openingBalance                Decimal                    @default(0) @db.Decimal(20, 10)
  openingBalanceDate            DateTime?                  @db.Date
  assets                        Asset[]
  recurringRules                RecurringTransactionRule[] @relation("StandardRecurringRuleAccount")
  recurringTransferDestinations RecurringTransactionRule[] @relation("TransferRecurringRuleDestination")
  recurringTransferSources      RecurringTransactionRule[] @relation("TransferRecurringRuleSource")
  transactions                  Transaction[]

  @@unique([id, userId])
  @@unique([userId, importSource, importKey])
  @@index([userId, archivedAt, order, createdAt])
}

model Category {
  id             String                     @id @default(cuid())
  userId         String
  name           String
  type           CategoryType
  order          Int                        @default(0)
  archivedAt     DateTime?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  importSource   ImportSource?
  importKey      String?
  budgets        CategoryBudget[]
  recurringRules RecurringTransactionRule[]
  transactions   Transaction[]

  @@unique([id, userId])
  @@unique([userId, importSource, importKey])
  @@index([userId, type, archivedAt, order, createdAt])
}

model CategoryBudget {
  id         String                   @id @default(cuid())
  userId     String
  categoryId String
  currency   String
  amount     Decimal                  @db.Decimal(20, 10)
  startMonth DateTime                 @db.Date
  endMonth   DateTime?                @db.Date
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
  category   Category                 @relation(fields: [categoryId, userId], references: [id, userId], onDelete: Cascade, onUpdate: Cascade)
  overrides  CategoryBudgetOverride[]

  @@unique([id, userId])
  @@unique([userId, categoryId, currency, startMonth])
  @@index([userId, startMonth, endMonth])
  @@index([userId, categoryId, currency, startMonth, endMonth])
}

model CategoryBudgetOverride {
  id               String         @id @default(cuid())
  userId           String
  categoryBudgetId String
  month            DateTime       @db.Date
  amount           Decimal        @db.Decimal(20, 10)
  note             String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  categoryBudget   CategoryBudget @relation(fields: [categoryBudgetId, userId], references: [id, userId], onDelete: Cascade)

  @@unique([categoryBudgetId, month])
  @@index([userId, month])
  @@index([userId, categoryBudgetId, month])
}

model PortfolioState {
  userId                 String    @id
  lastRefreshSucceededAt DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  refreshStartedAt       DateTime?
}

model IdempotencyRequest {
  userId             String
  method             String
  routePath          String
  idempotencyKey     String
  requestFingerprint String
  status             IdempotencyRequestStatus
  responseStatusCode Int?
  responseJson       Json?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  completedAt        DateTime?

  @@id([userId, method, routePath, idempotencyKey])
  @@index([userId, createdAt(sort: Desc)])
}

model OperationState {
  userId          String
  type            OperationType
  startedAt       DateTime?
  lastSucceededAt DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@id([userId, type])
  @@index([userId, updatedAt(sort: Desc)])
}

model NetWorthSnapshot {
  id               String   @id @default(cuid())
  userId           String
  snapshotDate     DateTime @db.Date
  capturedAt       DateTime
  baseCurrency     String   @default("EUR")
  assetsTotal      Decimal  @db.Decimal(20, 10)
  liabilitiesTotal Decimal  @db.Decimal(20, 10)
  netWorthTotal    Decimal  @db.Decimal(20, 10)
  unavailableCount Int      @default(0)
  isPartial        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, snapshotDate, baseCurrency])
  @@index([userId, snapshotDate])
}

model Transaction {
  id                       String                    @id @default(cuid())
  userId                   String
  importSource             ImportSource?
  importKey                String?
  postedAt                 DateTime
  accountId                String
  categoryId               String?
  amount                   Decimal                   @db.Decimal(20, 10)
  currency                 String
  direction                TransactionDirection
  kind                     TransactionKind
  description              String
  notes                    String?
  counterparty             String?
  transferGroupId          String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  recurringRuleId          String?
  recurringOccurrenceMonth DateTime?                 @db.Date
  account                  Account                   @relation(fields: [accountId, userId], references: [id, userId], onUpdate: Cascade)
  category                 Category?                 @relation(fields: [categoryId, userId], references: [id, userId], onUpdate: Cascade)
  recurringRule            RecurringTransactionRule? @relation(fields: [recurringRuleId], references: [id])

  @@unique([userId, importSource, importKey, direction])
  @@unique([userId, recurringRuleId, recurringOccurrenceMonth, direction], map: "Transaction_userId_recurringRuleId_recurringOccurrenceMonth_dir")
  @@index([userId, postedAt])
  @@index([userId, kind, postedAt])
  @@index([userId, accountId, postedAt])
  @@index([userId, categoryId, postedAt])
  @@index([userId, transferGroupId])
  @@index([userId, recurringRuleId, recurringOccurrenceMonth])
}

model RecurringTransactionRule {
  id                         String                           @id @default(cuid())
  userId                     String
  name                       String
  isActive                   Boolean                          @default(true)
  kind                       TransactionKind
  amount                     Decimal                          @db.Decimal(20, 10)
  dayOfMonth                 Int
  startDate                  DateTime                         @db.Date
  endDate                    DateTime?                        @db.Date
  accountId                  String?
  direction                  TransactionDirection?
  categoryId                 String?
  counterparty               String?
  sourceAccountId            String?
  destinationAccountId       String?
  description                String
  notes                      String?
  lastMaterializationError   String?
  lastMaterializationErrorAt DateTime?
  createdAt                  DateTime                         @default(now())
  updatedAt                  DateTime                         @default(now()) @updatedAt
  account                    Account?                         @relation("StandardRecurringRuleAccount", fields: [accountId, userId], references: [id, userId], onDelete: SetNull)
  category                   Category?                        @relation(fields: [categoryId, userId], references: [id, userId], onDelete: SetNull)
  destinationAccount         Account?                         @relation("TransferRecurringRuleDestination", fields: [destinationAccountId, userId], references: [id, userId], onDelete: SetNull)
  occurrences                RecurringTransactionOccurrence[]
  sourceAccount              Account?                         @relation("TransferRecurringRuleSource", fields: [sourceAccountId, userId], references: [id, userId], onDelete: SetNull)
  transactions               Transaction[]

  @@index([userId, accountId])
  @@index([userId, sourceAccountId])
  @@index([userId, destinationAccountId])
  @@index([userId, isActive, dayOfMonth, startDate], map: "RecurringTransactionRule_userId_isActive_dayOfMonth_startDate_i")
}

model RecurringTransactionOccurrence {
  id                           String                    @id @default(cuid())
  userId                       String
  recurringRuleId              String
  occurrenceMonth              DateTime                  @db.Date
  status                       RecurringOccurrenceStatus
  overrideAmount               Decimal?                  @db.Decimal(20, 10)
  overridePostedAtDate         DateTime?                 @db.Date
  overrideAccountId            String?
  overrideDirection            TransactionDirection?
  overrideCategoryId           String?
  overrideCounterparty         String?
  overrideSourceAccountId      String?
  overrideDestinationAccountId String?
  overrideDescription          String?
  overrideNotes                String?
  createdAt                    DateTime                  @default(now())
  updatedAt                    DateTime                  @default(now()) @updatedAt
  recurringRule                RecurringTransactionRule  @relation(fields: [recurringRuleId], references: [id], onDelete: Cascade)

  @@unique([recurringRuleId, occurrenceMonth])
  @@index([userId, occurrenceMonth])
  @@index([userId, recurringRuleId, occurrenceMonth])
}

model ImportBatch {
  id          String            @id @default(cuid())
  userId      String
  source      ImportSource
  status      ImportBatchStatus
  summaryJson Json
  errorJson   Json
  payloadJson Json?
  createdAt   DateTime          @default(now())
  appliedAt   DateTime?

  @@index([userId, createdAt(sort: Desc)])
}

enum AssetType {
  ASSET
  LIABILITY
}

enum AssetKind {
  CASH
  STOCK
  BOND
  CRYPTO
  REAL_ESTATE
  PENSION
  COMMODITY
  OTHER
}

enum LiabilityKind {
  TAX
  DEBT
  OTHER
}

enum AccountType {
  BANK
  BROKER
  CARD
  CASH
  LOAN
  OTHER
}

enum CategoryType {
  EXPENSE
  INCOME
}

enum TransactionKind {
  EXPENSE
  INCOME
  TRANSFER
  ADJUSTMENT
}

enum TransactionDirection {
  INFLOW
  OUTFLOW
}

enum RecurringOccurrenceStatus {
  SKIPPED
  OVERRIDDEN
}

enum ImportBatchStatus {
  PREVIEW
  APPLIED
  FAILED
}

enum ImportSource {
  CSV_TEMPLATE
}

enum IdempotencyRequestStatus {
  IN_PROGRESS
  COMPLETED
}

enum OperationType {
  ASSET_REFRESH
  SNAPSHOT_CAPTURE
  RECURRING_MATERIALIZE
}
