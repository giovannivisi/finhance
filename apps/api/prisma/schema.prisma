generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Asset {
  id         String     @id @default(cuid())
  userId     String?
  name       String
  kind         AssetKind?
  liabilityKind LiabilityKind?
  ticker      String?
  quantity    Decimal?   @db.Decimal(20, 10)
  unitPrice   Decimal?   @db.Decimal(20, 10)
  notes       String?
  order       Int?       @default(0)
  type       AssetType
  balance    Decimal    @db.Decimal(14, 2)
  currency   String     @default("EUR")
  categoryId String?
  category   Category?  @relation(fields: [categoryId], references: [id])
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

enum AssetType {
  ASSET
  LIABILITY
}

enum AssetKind {
  CASH
  STOCK
  BOND
  CRYPTO
  REAL_ESTATE
  PENSION
  COMMODITY
  OTHER
}

enum LiabilityKind {
  TAX
  DEBT
  OTHER
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  assets    Asset[]
}