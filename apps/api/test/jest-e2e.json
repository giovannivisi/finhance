{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/src/$1",
    "^@accounts/(.*)$": "<rootDir>/src/accounts/$1",
    "^@assets/(.*)$": "<rootDir>/src/assets/$1",
    "^@budgets/(.*)$": "<rootDir>/src/budgets/$1",
    "^@recurring/(.*)$": "<rootDir>/src/recurring/$1",
    "^@imports/(.*)$": "<rootDir>/src/imports/$1",
    "^@snapshots/(.*)$": "<rootDir>/src/snapshots/$1",
    "^@transactions/(.*)$": "<rootDir>/src/transactions/$1",
    "^@prices/(.*)$": "<rootDir>/src/prices/$1",
    "^@prisma/(prisma\\..*)$": "<rootDir>/src/prisma/$1"
  }
}
